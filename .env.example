# ═══════════════════════════════════════════════════════════════════
# RONIN v3.0 — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─── REQUIRED ───────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Venice AI API key — get one at https://venice.ai/
# Optional: enables dual-provider routing for cost optimization + privacy
VENICE_API_KEY=

# ─── SERVER CONFIG ──────────────────────────────────────────────
# MCP server transport: "stdio" (local) or "http" (remote/docker)
MCP_TRANSPORT=http
MCP_PORT=8741
MCP_HOST=0.0.0.0

# REST API port (FastAPI wrapper for frontend tool execution)
API_PORT=8742

# ─── PATHS ──────────────────────────────────────────────────────
# Where RONIN stores its data (memory DB, workspace files, audit log)
RONIN_HOME=~/.ronin

# ─── SAFETY BOUNDS ──────────────────────────────────────────────
# Max seconds a shell command can run before timeout
MAX_SHELL_TIMEOUT=30
# Max characters in tool output before truncation
MAX_OUTPUT_LENGTH=8000
# Max file size in bytes for file operations
MAX_FILE_SIZE=1000000

# ─── FRONTEND ───────────────────────────────────────────────────
VITE_MCP_SERVER_URL=http://localhost:8741
VITE_API_URL=http://localhost:8742
VITE_API_MODEL=claude-sonnet-4-20250514

# ─── OPTIONAL: FUTURE PHASES ───────────────────────────────────
# Redis URL for production memory backend (Phase 2)
# REDIS_URL=redis://localhost:6379
# A2A Agent Registry endpoint (Phase 3)
# A2A_REGISTRY_URL=http://localhost:8742
